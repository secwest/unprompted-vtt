# Copy this file to .env and fill in your Zoom app credentials.
# Do not commit the real .env file.

ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# Optional: if you only want recordings owned by a single Zoom user,
# set their email address or user ID here.
ZOOM_USER_ID=
